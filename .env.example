# Πρότυπο .env (ΠΟΤΕ commit το πραγματικό .env -- gitignored).
# Αντιγραφή: cp .env.example .env και συμπλήρωση πραγματικών τιμών.

# E8 (docker-compose.graph.yml): τοπικό Neo4j -- ΜΟΝΟ placeholder εδώ.
NEO4J_PASSWORD=change-me

# E1 (scripts/r2_sync.py): Cloudflare R2 credentials (προαιρετικά τοπικά --
# στο CI έρχονται από GitHub secrets).
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=ellada30-data

# P2-B1 (src/gemi/client.py): ΓΕΜΗ Open Data API key (opendata.businessportal.gr).
