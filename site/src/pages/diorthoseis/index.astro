---
import Base from "../../layouts/Base.astro";
---
<Base title="Αρχείο Διορθώσεων" description="Υπέβαλε αίτημα διόρθωσης ή απάντησης και δες το δημόσιο αρχείο εκβάσεων.">
  <h1>Διορθώσεις & δικαίωμα απάντησης</h1>
  <p class="subtitle">
    Αν εντόπισες λάθος σε δεδομένα ή υπολογισμό, ή θέλεις να καταθέσεις επίσημη απάντηση/διευκρίνιση για έναν φορέα,
    χρησιμοποίησε τη φόρμα παρακάτω. Ισχύει το <a href="/apopoiisi/">δικαίωμα απάντησης</a> με το SLA που περιγράφεται εκεί.
  </p>

  <section id="form" class="form-section">
    <h2>Υποβολή αιτήματος</h2>
    <form id="correction-form" novalidate>
      <div class="form-row">
        <label for="cf-name">Όνομα <span class="muted">(προαιρετικό)</span></label>
        <input id="cf-name" name="name" type="text" maxlength="200" autocomplete="name" />
      </div>
      <div class="form-row">
        <label for="cf-email">Email <span class="muted">(απαραίτητο, για να απαντήσουμε)</span></label>
        <input id="cf-email" name="email" type="email" maxlength="200" required autocomplete="email" />
      </div>
      <div class="form-row entity-row">
        <label for="cf-entity">Αφορά φορέα <span class="muted">(προαιρετικό)</span></label>
        <input
          id="cf-entity"
          type="text"
          maxlength="200"
          autocomplete="off"
          placeholder="Όνομα φορέα ή ΑΦΜ…"
          aria-expanded="false"
          aria-controls="cf-entity-results"
        />
        <div id="cf-entity-results" class="search-results" role="listbox" hidden></div>
        <input id="cf-entity-vat" type="hidden" name="vat" value="" />
      </div>
      <div class="form-row">
        <label for="cf-message">Μήνυμα <span class="muted">(περιγραφή λάθους ή κείμενο απάντησης)</span></label>
        <textarea id="cf-message" name="message" rows="6" maxlength="5000" required></textarea>
      </div>
      <!-- honeypot: κρυφό πεδίο, μόνο bots το συμπληρώνουν -->
      <div class="hp-field" aria-hidden="true">
        <label for="cf-website">Ιστότοπος</label>
        <input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
      </div>
      <button type="submit" class="button-outline" id="cf-submit">Υποβολή</button>
      <p id="cf-status" class="form-status" role="status"></p>
      <p class="sla-note">
        Επιβεβαίωση παραλαβής εντός 2 εργάσιμων ημερών, ουσιαστική απάντηση εντός 5 εργάσιμων ημερών
        (έως 15 για σύνθετα αιτήματα) — βλ. <a href="/apopoiisi/">δικαίωμα απάντησης</a>.
        Αν προτιμάς, μπορείς και να στείλεις email απευθείας στο <a href="mailto:ellada30@proton.me">ellada30@proton.me</a>.
      </p>
    </form>
  </section>

  <section>
    <h2>Δημόσιο αρχείο</h2>
    <p class="subtitle">
      Κάθε αίτημα διόρθωσης ή απάντησης καταγράφεται εδώ μαζί με την έκβασή του, χωρίς προσωπικά στοιχεία αποστολέων.
    </p>
    <div class="empty-state">
      <p><strong>Κανένα αίτημα μέχρι σήμερα.</strong></p>
      <p>Η ύπαρξη αυτής της σελίδας από την πρώτη μέρα είναι η απόδειξη καλής πίστης της διαδικασίας.</p>
    </div>
  </section>
</Base>

<script>
  interface EntityIndexRow {
    vat: string;
    name: string;
    type?: string | null;
  }

  const params = new URLSearchParams(window.location.search);
  const prefillVat = params.get("vat") ?? "";
  const prefillName = params.get("name") ?? "";

  const entityInput = document.getElementById("cf-entity") as HTMLInputElement | null;
  const entityVat = document.getElementById("cf-entity-vat") as HTMLInputElement | null;
  const entityResults = document.getElementById("cf-entity-results");

  if (prefillVat && entityInput && entityVat) {
    entityInput.value = prefillName ? prefillName : `ΑΦΜ ${prefillVat}`;
    entityVat.value = prefillVat;
  }

  let entities: EntityIndexRow[] = [];
  let entitiesLoaded = false;
  let activeRows: EntityIndexRow[] = [];

  function clearEntityResults() {
    if (!entityResults || !entityInput) return;
    activeRows = [];
    entityResults.hidden = true;
    entityResults.replaceChildren();
    entityInput.setAttribute("aria-expanded", "false");
  }

  function renderEntityResults(rows: EntityIndexRow[]) {
    if (!entityResults || !entityInput) return;
    entityResults.replaceChildren();
    activeRows = rows;
    if (!rows.length) {
      clearEntityResults();
      return;
    }
    for (const row of rows) {
      const item = document.createElement("button");
      item.type = "button";
      item.className = "search-result";
      const name = document.createElement("span");
      name.textContent = row.name;
      const meta = document.createElement("small");
      meta.textContent = `${row.vat}${row.type ? ` · ${row.type}` : ""}`;
      item.append(name, meta);
      item.addEventListener("click", () => {
        if (!entityInput || !entityVat) return;
        entityInput.value = row.name;
        entityVat.value = row.vat;
        clearEntityResults();
      });
      entityResults.append(item);
    }
    entityResults.hidden = false;
    entityInput.setAttribute("aria-expanded", "true");
  }

  function scoreEntity(row: EntityIndexRow, q: string): number {
    const name = row.name.toLowerCase();
    const vat = row.vat;
    if (vat.startsWith(q)) return 0;
    if (name.startsWith(q)) return 1;
    if (name.includes(q)) return 2;
    return 99;
  }

  async function ensureEntitiesLoaded() {
    if (entitiesLoaded) return;
    entitiesLoaded = true;
    try {
      const res = await fetch("/data/entities-index.json");
      entities = await res.json();
    } catch {
      entities = [];
    }
  }

  if (entityInput) {
    entityInput.addEventListener("focus", () => {
      void ensureEntitiesLoaded();
    });

    entityInput.addEventListener("input", () => {
      if (entityVat) entityVat.value = "";
      const q = entityInput.value.trim().toLowerCase();
      if (q.length < 2 || !entities.length) {
        clearEntityResults();
        return;
      }
      const matches = entities
        .map((row) => ({ row, score: scoreEntity(row, q) }))
        .filter((r) => r.score < 99)
        .sort((a, b) => a.score - b.score || a.row.name.localeCompare(b.row.name, "el"))
        .slice(0, 8)
        .map((r) => r.row);
      renderEntityResults(matches);
    });

    entityInput.addEventListener("keydown", (event) => {
      if (event.key === "Escape") clearEntityResults();
      if (event.key === "Enter" && activeRows[0]) {
        event.preventDefault();
        entityInput.value = activeRows[0].name;
        if (entityVat) entityVat.value = activeRows[0].vat;
        clearEntityResults();
      }
    });

    document.addEventListener("click", (event) => {
      if (!entityInput.contains(event.target as Node) && !entityResults?.contains(event.target as Node)) {
        clearEntityResults();
      }
    });
  }

  const form = document.getElementById("correction-form");
  const status = document.getElementById("cf-status");
  const submitBtn = document.getElementById("cf-submit");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement) || !(submitBtn instanceof HTMLButtonElement) || !status) return;

    submitBtn.disabled = true;
    status.textContent = "Αποστολή...";
    status.className = "form-status";

    const payload = {
      name: (form.elements.namedItem("name") as HTMLInputElement)?.value ?? "",
      email: (form.elements.namedItem("email") as HTMLInputElement)?.value ?? "",
      message: (form.elements.namedItem("message") as HTMLTextAreaElement)?.value ?? "",
      website: (form.elements.namedItem("website") as HTMLInputElement)?.value ?? "",
      vat: (form.elements.namedItem("vat") as HTMLInputElement)?.value ?? "",
      entityName: entityInput?.value.trim() ?? "",
    };

    try {
      const res = await fetch("/api/submit-correction", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        status.textContent = "Το αίτημα εστάλη. Θα λάβεις επιβεβαίωση παραλαβής εντός 2 εργάσιμων ημερών.";
        status.className = "form-status success";
        form.reset();
      } else {
        status.textContent = "Κάτι πήγε στραβά. Δοκίμασε ξανά ή στείλε email στο ellada30@proton.me.";
        status.className = "form-status error";
      }
    } catch {
      status.textContent = "Κάτι πήγε στραβά. Δοκίμασε ξανά ή στείλε email στο ellada30@proton.me.";
      status.className = "form-status error";
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .form-section { margin-block: 1.5rem 2.5rem; }
  #correction-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 40rem;
  }
  .form-row { display: flex; flex-direction: column; gap: 0.3rem; }
  .form-row label { font-size: 0.85rem; color: var(--text); }
  .form-row input,
  .form-row textarea {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.65rem;
    background: var(--surface);
    color: var(--text);
    font: inherit;
  }
  .entity-row { position: relative; }
  .entity-row .search-results { inset-inline-start: 0; inset-inline-end: auto; width: 100%; max-width: 40rem; }
  .entity-row .search-result {
    width: 100%;
    border: 0;
    border-bottom: 1px solid var(--border);
    background: none;
    text-align: left;
    font: inherit;
    cursor: pointer;
  }
  .hp-field { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  #correction-form button[type="submit"] { align-self: flex-start; cursor: pointer; }
  .form-status { min-height: 1.2em; font-size: 0.9rem; }
  .form-status.success { color: var(--accent-strong); }
  .form-status.error { color: #b3261e; }
  .sla-note { font-size: 0.8rem; color: var(--muted); }
</style>
