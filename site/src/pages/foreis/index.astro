---
import Base from "../../layouts/Base.astro";

const columns = [
  { key: "name", label: "Φορέας" },
  { key: "org_type", label: "Τύπος" },
  { key: "nuts_city", label: "Περιοχή" },
  { key: "year", label: "Έτος" },
  { key: "n_total", label: "N αναθέσεων" },
  { key: "da_count_pct", label: "% απευθείας (πλήθος)", info: "Μερίδιο αναθέσεων με τη διαδικασία «Απευθείας ανάθεση». Μικροί φορείς με λίγες προμηθειες έχουν φυσιολογικά υψηλό ποσοστό σε πλήθος — δείτε πάντα και το N." },
  { key: "da_value_pct", label: "% απευθείας (αξία)", info: "Το ίδιο μερίδιο υπολογισμένο σε αξία αντί για πλήθος αναθέσεων." },
  { key: "hhi", label: "HHI αναδόχων", info: "Συγκέντρωση δαπανών σε λίγους αναδόχους (0–1). Εξειδικευμένες αγορές έχουν εγγενώς λίγους προμηθευτές· απαιτείται ελάχιστο N≥10." },
  { key: "median_discount_pct", label: "Διάμεση έκπτωση %", info: "Διαφορά εκτιμώμενης προς τελική αξία. Συστηματικά ~0% έκπτωση σε ανταγωνιστικές διαδικασίες είναι καθιερωμένο red flag, όχι μεμονωμένη τιμή." },
];
---
<Base title="Φορείς" description="Δείκτες διαφάνειας διαδικασιών ανά φορέα.">
  <h1>Δείκτες διαφάνειας διαδικασιών ανά φορέα</h1>
  <p class="subtitle">Στατιστικά μεγέθη και δείκτες ρίσκου διαδικασιών — δείτε πάντα το N και την περίοδο δίπλα σε κάθε τιμή.</p>

  <div class="controls">
    <input id="search" type="text" placeholder="Αναζήτηση φορέα..." />
    <span id="status">Φόρτωση δεδομένων...</span>
  </div>

  <div class="table-wrap">
    <table id="indicators-table">
      <thead>
        <tr>
          {columns.map((col) => (
            <th data-key={col.key}>
              {col.label}
              {col.info && <span class="info-icon" title={col.info}>ⓘ</span>}
            </th>
          ))}
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>
</Base>

<script>
  type Rec = Record<string, string | number | null>;

  const state: { records: Rec[]; sortKey: string; sortDir: number; group: string | null } = {
    records: [],
    sortKey: "n_total",
    sortDir: -1,
    group: null,
  };

  const NUMERIC_KEYS = new Set(["year", "n_total", "da_count_pct", "da_value_pct", "hhi", "median_discount_pct"]);
  const COLS = ["name", "org_type", "nuts_city", "year", "n_total", "da_count_pct", "da_value_pct", "hhi", "median_discount_pct"];
  const INTENSITY_KEYS = ["da_count_pct", "da_value_pct", "hhi", "median_discount_pct"];

  const GROUP_MATCHERS: Record<string, (orgType: string) => boolean> = {
    ota: (t) => t.includes("τοπική") || t.includes("Περιφερειακή"),
    central: (t) => t.includes("Υπουργείο") || t.includes("Κεντρική"),
    other: (t) => !GROUP_MATCHERS.ota(t) && !GROUP_MATCHERS.central(t),
  };

  function fmt(value: string | number | null, key: string): string {
    if (value === null || value === undefined) return '<span class="badge-missing">Ανεπαρκή δεδομένα</span>';
    if (key === "hhi") return Number(value).toFixed(3);
    if (NUMERIC_KEYS.has(key) && key !== "year" && key !== "n_total") return `${Number(value).toFixed(1)}%`;
    return String(value);
  }

  function median(values: number[]): number | null {
    if (!values.length) return null;
    const sorted = values.slice().sort((a, b) => a - b);
    const mid = Math.floor(sorted.length / 2);
    return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
  }

  function computeMedians(records: Rec[]): Record<string, number | null> {
    const medians: Record<string, number | null> = {};
    for (const key of INTENSITY_KEYS) {
      const values = records.map((r) => r[key]).filter((v): v is number => typeof v === "number");
      medians[key] = median(values);
    }
    return medians;
  }

  function intensityClass(value: number, m: number): string {
    if (value <= m) return "";
    const ratio = m > 0 ? value / m : value;
    if (ratio > 2) return "intensity-3";
    if (ratio > 1.4) return "intensity-2";
    return "intensity-1";
  }

  function render() {
    const q = (document.getElementById("search") as HTMLInputElement).value.trim().toLowerCase();
    let rows = state.records;

    if (state.group && GROUP_MATCHERS[state.group]) {
      rows = rows.filter((r) => GROUP_MATCHERS[state.group as string](String(r.org_type || "")));
    }
    if (q) {
      rows = rows.filter((r) => String(r.name || "").toLowerCase().includes(q));
    }

    rows = rows.slice().sort((a, b) => {
      const av = a[state.sortKey];
      const bv = b[state.sortKey];
      if (av === null || av === undefined) return 1;
      if (bv === null || bv === undefined) return -1;
      if (av < bv) return -1 * state.sortDir;
      if (av > bv) return 1 * state.sortDir;
      return 0;
    });

    const medians = computeMedians(rows);
    const body = document.getElementById("table-body")!;
    body.innerHTML = rows
      .slice(0, 500)
      .map((r) => {
        const cells = COLS.map((c) => {
          const value = r[c];
          const isIntensity = INTENSITY_KEYS.includes(c) && typeof value === "number";
          const m = medians[c];
          let cls = "";
          if (isIntensity && m !== null && m !== undefined) {
            const above = (value as number) > m;
            cls = [above ? "above-median" : "", intensityClass(value as number, m)].filter(Boolean).join(" ");
          }
          let content = fmt(value, c);
          if (c === "name" && r.vat) {
            content = `<a href="/foreas/${r.vat}/">${content}</a>`;
          }
          return `<td${cls ? ` class="${cls}"` : ""}>${content}</td>`;
        }).join("");
        return `<tr>${cells}</tr>`;
      })
      .join("");

    document.getElementById("status")!.textContent =
      `${rows.length} γραμμές φορέα/έτους (εμφανίζονται έως 500) · ▲ = άνω του εθνικού διαμέσου`;
  }

  function attachSorting() {
    document.querySelectorAll("th[data-key]").forEach((th) => {
      th.addEventListener("click", () => {
        const key = (th as HTMLElement).dataset.key!;
        if (state.sortKey === key) {
          state.sortDir *= -1;
        } else {
          state.sortKey = key;
          state.sortDir = 1;
        }
        render();
      });
    });
  }

  async function main() {
    attachSorting();
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    const group = params.get("group");
    if (q) (document.getElementById("search") as HTMLInputElement).value = q;
    if (group) state.group = group;

    document.getElementById("search")!.addEventListener("input", render);

    try {
      const res = await fetch("/data/indicators.json");
      const payload = await res.json();
      state.records = payload.records;
      render();
    } catch (err) {
      document.getElementById("status")!.textContent =
        "Σφάλμα φόρτωσης δεδομένων.";
    }
  }

  main();
</script>
