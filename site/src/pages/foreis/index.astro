---
import Base from "../../layouts/Base.astro";

const columns = [
  { key: "compare", label: "Σύγκριση" },
  { key: "name", label: "Φορέας" },
  { key: "org_type", label: "Τύπος" },
  { key: "nuts_city", label: "Περιοχή" },
  { key: "year", label: "Έτος" },
  { key: "n_total", label: "N αναθέσεων" },
  { key: "da_count_pct", label: "% απευθείας (πλήθος)", info: "Μερίδιο αναθέσεων με τη διαδικασία «Απευθείας ανάθεση». Μικροί φορείς με λίγες προμηθειες έχουν φυσιολογικά υψηλό ποσοστό σε πλήθος — δείτε πάντα και το N." },
  { key: "da_value_pct", label: "% απευθείας (αξία)", info: "Το ίδιο μερίδιο υπολογισμένο σε αξία αντί για πλήθος αναθέσεων." },
  { key: "hhi", label: "HHI αναδόχων", info: "Συγκέντρωση δαπανών σε λίγους αναδόχους (0–1). Εξειδικευμένες αγορές έχουν εγγενώς λίγους προμηθευτές· απαιτείται ελάχιστο N≥10." },
  { key: "median_discount_pct", label: "Διάμεση έκπτωση %", info: "Διαφορά εκτιμώμενης προς τελική αξία. Συστηματικά ~0% έκπτωση σε ανταγωνιστικές διαδικασίες είναι καθιερωμένο red flag, όχι μεμονωμένη τιμή." },
  { key: "single_bid_pct", label: "Single-bid %", info: "Μερίδιο ανταγωνιστικών διαδικασιών με μία προσφορά. Δημοσιεύεται μόνο μετά το cutover 2025-04 και με N≥5." },
  { key: "composite_score", label: "Σύνθετος", info: "Μη σταθμισμένος μέσος δημοσιευμένων flags. Δεν περιλαμβάνει bid-splitting ή pct_short_deadline." },
];
---
<Base title="Φορείς" description="Δείκτες διαφάνειας διαδικασιών ανά φορέα.">
  <h1>Δείκτες διαφάνειας διαδικασιών ανά φορέα</h1>
  <p class="subtitle">Στατιστικά μεγέθη και δείκτες ρίσκου διαδικασιών — δείτε πάντα το N και την περίοδο δίπλα σε κάθε τιμή.</p>

  <div class="controls">
    <input id="search" type="text" placeholder="Αναζήτηση φορέα..." />
    <span id="status">Φόρτωση δεδομένων...</span>
  </div>
  <p class="subtitle">Ο πίνακας δείχνει το τελευταίο διαθέσιμο έτος ανά φορέα (P2-01 — ελαφρύ αρχείο). Για πλήρες ιστορικό ανά έτος δείτε το προφίλ του φορέα.</p>

  <section id="compare-panel" class="compare-panel" hidden></section>
  <section id="group-summary" class="group-summary" aria-live="polite"></section>

  <div class="table-wrap">
    <table id="indicators-table">
      <thead>
        <tr>
          {columns.map((col) => (
            <th data-key={col.key}>
              {col.label}
              {col.info && <span class="info-icon" title={col.info}>ⓘ</span>}
            </th>
          ))}
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>
</Base>

<script>
  type Rec = Record<string, string | number | null>;

  const state: { records: Rec[]; sortKey: string; sortDir: number; group: string | null; selected: Set<string> } = {
    records: [],
    sortKey: "n_total",
    sortDir: -1,
    group: null,
    selected: new Set(),
  };

  const NUMERIC_KEYS = new Set(["year", "n_total", "da_count_pct", "da_value_pct", "hhi", "median_discount_pct", "single_bid_pct", "composite_score"]);
  const COLS = ["compare", "name", "org_type", "nuts_city", "year", "n_total", "da_count_pct", "da_value_pct", "hhi", "median_discount_pct", "single_bid_pct", "composite_score"];
  const INTENSITY_KEYS = ["da_count_pct", "da_value_pct", "hhi", "median_discount_pct", "single_bid_pct", "composite_score"];

  const GROUP_MATCHERS: Record<string, (orgType: string) => boolean> = {
    ota: (t) => t.includes("τοπική") || t.includes("Περιφερειακή"),
    central: (t) => t.includes("Υπουργείο") || t.includes("Κεντρική"),
    other: (t) => !GROUP_MATCHERS.ota(t) && !GROUP_MATCHERS.central(t),
  };

  // S1 (audit): name/org_type/nuts_city προέρχονται από ΚΗΜΔΗΣ -- δεδομένα
  // τρίτων, μη ελεγχόμενα -- και μπαίνουν σε innerHTML παρακάτω. Χωρίς αυτό
  // το escaping ένα όνομα φορέα με `<img src=x onerror=...>` θα εκτελούνταν.
  function esc(value: string): string {
    return value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  // Το ΑΦΜ (r.vat) μπαίνει ανεξέλεγκτο σε href attribute -- ελέγχουμε μορφή
  // (9 ψηφία) πριν το χρησιμοποιήσουμε, ώστε ένα scheme (π.χ. javascript:)
  // να μην περάσει ποτέ ως τιμή.
  function isValidVat(vat: unknown): vat is string {
    return typeof vat === "string" && /^\d{9}$/.test(vat);
  }

  function fmt(value: string | number | null, key: string): string {
    if (value === null || value === undefined) return '<span class="badge-missing">Ανεπαρκή δεδομένα</span>';
    if (key === "hhi") return Number(value).toFixed(3);
    if (key === "composite_score") return Number(value).toFixed(3);
    if (NUMERIC_KEYS.has(key) && key !== "year" && key !== "n_total") return `${Number(value).toFixed(1)}%`;
    return esc(String(value));
  }

  function median(values: number[]): number | null {
    if (!values.length) return null;
    const sorted = values.slice().sort((a, b) => a - b);
    const mid = Math.floor(sorted.length / 2);
    return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
  }

  function computeMedians(records: Rec[]): Record<string, number | null> {
    const medians: Record<string, number | null> = {};
    for (const key of INTENSITY_KEYS) {
      const values = records.map((r) => r[key]).filter((v): v is number => typeof v === "number");
      medians[key] = median(values);
    }
    return medians;
  }

  function applyFilters(): Rec[] {
    const q = (document.getElementById("search") as HTMLInputElement).value.trim().toLowerCase();
    let rows = state.records;

    if (state.group && GROUP_MATCHERS[state.group]) {
      rows = rows.filter((r) => GROUP_MATCHERS[state.group as string](String(r.org_type || "")));
    }
    if (q) {
      rows = rows.filter((r) => String(r.name || "").toLowerCase().includes(q));
    }
    return rows;
  }

  function intensityClass(value: number, m: number): string {
    if (value <= m) return "";
    const ratio = m > 0 ? value / m : value;
    if (ratio > 2) return "intensity-3";
    if (ratio > 1.4) return "intensity-2";
    return "intensity-1";
  }

  function render() {
    let rows = applyFilters();

    rows = rows.slice().sort((a, b) => {
      const av = a[state.sortKey];
      const bv = b[state.sortKey];
      if (av === null || av === undefined) return 1;
      if (bv === null || bv === undefined) return -1;
      if (av < bv) return -1 * state.sortDir;
      if (av > bv) return 1 * state.sortDir;
      return 0;
    });

    const medians = computeMedians(rows);
    const body = document.getElementById("table-body")!;
    body.innerHTML = rows
      .slice(0, 500)
      .map((r) => {
        const cells = COLS.map((c) => {
          if (c === "compare") {
            const checked = typeof r.vat === "string" && state.selected.has(r.vat);
            const disabled = !checked && state.selected.size >= 4;
            return `<td data-label="Σύγκριση"><input type="checkbox" class="compare-check" data-vat="${esc(String(r.vat || ""))}" ${checked ? "checked" : ""} ${disabled ? "disabled" : ""} aria-label="Σύγκριση φορέα"></td>`;
          }
          const value = r[c];
          const isIntensity = INTENSITY_KEYS.includes(c) && typeof value === "number";
          const m = medians[c];
          let cls = "";
          if (isIntensity && m !== null && m !== undefined) {
            const above = (value as number) > m;
            cls = [above ? "above-median" : "", intensityClass(value as number, m)].filter(Boolean).join(" ");
          }
          let content = fmt(value, c);
          if (c === "name" && isValidVat(r.vat)) {
            content = `<a href="/foreas/${r.vat}/">${content}</a>`;
          }
          const label = document.querySelector(`th[data-key="${c}"]`)?.textContent?.trim() || c;
          return `<td data-label="${esc(label)}"${cls ? ` class="${cls}"` : ""}>${content}</td>`;
        }).join("");
        return `<tr>${cells}</tr>`;
      })
      .join("");

    document.getElementById("status")!.textContent =
      `${rows.length} φορείς (εμφανίζονται έως 500) · ▲ = άνω του εθνικού διαμέσου`;
    attachCompareChecks();
    renderCompare(rows);
    renderGroupSummary(rows);
  }

  function renderGroupSummary(rows: Rec[]) {
    const host = document.getElementById("group-summary")!;
    const groups = new Map<string, { nRows: number; nTotal: number; valueTotal: number }>();
    for (const r of rows) {
      const key = String(r.org_type || "Άγνωστο");
      const g = groups.get(key) || { nRows: 0, nTotal: 0, valueTotal: 0 };
      g.nRows += 1;
      g.nTotal += Number(r.n_total || 0);
      g.valueTotal += Number(r.value_total || 0);
      groups.set(key, g);
    }
    const top = Array.from(groups.entries()).sort((a, b) => b[1].nTotal - a[1].nTotal).slice(0, 6);
    host.innerHTML = `<h2>Σύνολα ανά ομάδα</h2><div class="summary-grid">${top.map(([name, g]) => `
      <div class="summary-card">
        <strong>${esc(name)}</strong>
        <span>${g.nRows.toLocaleString("el-GR")} γραμμές</span>
        <span>${g.nTotal.toLocaleString("el-GR")} αναθέσεις</span>
      </div>`).join("")}</div>`;
  }

  function renderCompare(rows: Rec[]) {
    const panel = document.getElementById("compare-panel")!;
    const selectedRows = Array.from(state.selected)
      .map((vat) => rows.find((r) => r.vat === vat) || state.records.find((r) => r.vat === vat))
      .filter(Boolean) as Rec[];
    panel.hidden = selectedRows.length === 0;
    if (!selectedRows.length) {
      panel.innerHTML = "";
      return;
    }
    const medians = computeMedians(rows);
    const metrics = [
      ["da_count_pct", "% απευθείας"],
      ["hhi", "HHI"],
      ["median_discount_pct", "Έκπτωση"],
      ["single_bid_pct", "Single-bid"],
      ["composite_score", "Σύνθετος"],
    ];
    panel.innerHTML = `
      <div class="compare-head">
        <h2>Σύγκριση φορέων</h2>
        <button type="button" id="clear-compare">Καθαρισμός</button>
      </div>
      <p class="subtitle">Έως 4 φορείς · baseline = εθνική διάμεσος του τρέχοντος φίλτρου έτους/ομάδας.</p>
      <div class="compare-grid">
        ${selectedRows.map((r) => `
          <article class="compare-card">
            <h3>${esc(String(r.name || r.vat))}</h3>
            <p class="muted">ΑΦΜ ${esc(String(r.vat))} · ${esc(String(r.year || "—"))}</p>
            ${metrics.map(([key, label]) => `
              <div class="compare-row">
                <span>${label}</span>
                <strong>${fmt(r[key], key)}</strong>
                <small>διάμεσος: ${medians[key] === null ? "—" : fmt(medians[key], key)}</small>
              </div>`).join("")}
          </article>`).join("")}
      </div>`;
    document.getElementById("clear-compare")?.addEventListener("click", () => {
      state.selected.clear();
      render();
    });
  }

  function attachCompareChecks() {
    document.querySelectorAll<HTMLInputElement>(".compare-check").forEach((box) => {
      box.addEventListener("change", () => {
        const vat = box.dataset.vat;
        if (!vat) return;
        if (box.checked && state.selected.size < 4) state.selected.add(vat);
        if (!box.checked) state.selected.delete(vat);
        render();
      });
    });
  }

  function attachSorting() {
    document.querySelectorAll("th[data-key]").forEach((th) => {
      th.addEventListener("click", () => {
        const key = (th as HTMLElement).dataset.key!;
        if (state.sortKey === key) {
          state.sortDir *= -1;
        } else {
          state.sortKey = key;
          state.sortDir = 1;
        }
        render();
      });
    });
  }

  async function main() {
    attachSorting();
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    const group = params.get("group");
    if (q) (document.getElementById("search") as HTMLInputElement).value = q;
    if (group) state.group = group;

    document.getElementById("search")!.addEventListener("input", render);

    try {
      const res = await fetch("/data/indicators-slim.json");
      const payload = await res.json();
      state.records = payload.records;
      render();
    } catch (err) {
      document.getElementById("status")!.textContent =
        "Σφάλμα φόρτωσης δεδομένων.";
    }
  }

  main();
</script>
