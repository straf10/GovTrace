---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import Base from "../../../layouts/Base.astro";
import IndicatorCard from "../../../components/IndicatorCard.astro";
import { stackedValueSvg, type YearSplit } from "../../../lib/charts";

// ΠΡΟΣΟΧΗ: getStaticPaths τρέχει ΜΙΑ φορά για όλο το route, αλλά το
// module-level frontmatter (έξω από getStaticPaths) τρέχει ΞΑΝΑ για ΚΑΘΕ
// σελίδα (3.217 φορές). Γι' αυτό τα 41MB foreas_pages.json διαβάζονται
// ΜΟΝΟ μέσα στο getStaticPaths, και σε κάθε σελίδα περνάει μέσω props
// μόνο το δικό της record (+ το μικρό distributions.json, ~43KB, φτηνό
// να περάσει ολόκληρο).
// process.cwd() είναι το site/ (εκεί τρέχει το `astro build`/`astro dev`) --
// πιο αξιόπιστο από import.meta.url εδώ, που το bundling του Astro build
// μετατοπίζει σε διαφορετικό σχετικό βάθος από το πηγαίο αρχείο.
export async function getStaticPaths() {
  const DATA_DIR = join(process.cwd(), "src", "data");
  const pages: Record<string, any> = JSON.parse(readFileSync(join(DATA_DIR, "foreas_pages.json"), "utf-8"));
  const distributions: Record<string, any> = JSON.parse(readFileSync(join(DATA_DIR, "distributions.json"), "utf-8"));
  // P2-17: γείτονες δικτύου συνδέονται σε /anadoxos/<vat>/ ΜΟΝΟ αν ο ανάδοχος
  // είναι μέσα στα top-N προφίλ (P2-16, βλ. R-01) -- αλλιώς broken link (404).
  let anadoxosVats: string[] = [];
  try {
    anadoxosVats = JSON.parse(readFileSync(join(process.cwd(), "public", "data", "anadoxos-index.json"), "utf-8"));
  } catch {
    anadoxosVats = [];
  }
  return Object.keys(pages).map((vat) => ({
    params: { vat },
    props: { page: pages[vat], distributions, anadoxosVats },
  }));
}

interface Props {
  page: any;
  distributions: Record<string, any>;
  anadoxosVats: string[];
}

const { vat } = Astro.params;
const { page, distributions, anadoxosVats } = Astro.props as Props;
const profiledVats = new Set(anadoxosVats);

const nf = new Intl.NumberFormat("el-GR", { maximumFractionDigits: 0 });
const eur = (v: number | null) => (v === null || v === undefined ? "—" : `${nf.format(v)} €`);

const years: number[] = page.years ?? [];
const latestYear = years.length ? years[years.length - 1] : null;
const latestOverview = latestYear !== null ? page.overview[String(latestYear)] : null;

const stackedRows: YearSplit[] = years.map((y) => {
  const o = page.overview[String(y)] ?? {};
  return { year: y, direct: 0, total: o.value_total ?? 0 };
});
// Δεν έχουμε ξεχωριστή αξία "μόνο απευθείας" υπολογισμένη στο build_foreas_data
// -- προσεγγίζουμε με το da_pct * value_total ως εκτίμηση για το stacked chart.
for (const row of stackedRows) {
  const o = page.overview[String(row.year)] ?? {};
  row.direct = ((o.da_pct ?? 0) / 100) * row.total;
}
const stackedSvg = stackedValueSvg(stackedRows);

function indicatorInput(key: "da" | "hhi" | "single_bid" | "discount" | "deadline" | "composite") {
  const series = page.indicators?.[key] ?? {};
  const points = years.map((y) => {
    const entry = series[String(y)];
    const value = key === "hhi" ? entry?.value : entry?.value;
    return { year: y, value: value ?? null };
  });
  const latest = latestYear !== null ? series[String(latestYear)] : null;
  const group = page.group_label;
  const distKey = group ? `${key}|${group}|${latestYear}` : null;
  const hist = distKey ? distributions[distKey] : null;
  const percentile = page.percentiles?.[key]?.[String(latestYear)] ?? null;
  return { points, latest, hist, percentile };
}

const da = indicatorInput("da");
const hhi = indicatorInput("hhi");
const singleBid = indicatorInput("single_bid");
const discount = indicatorInput("discount");
const deadline = indicatorInput("deadline");
const composite = indicatorInput("composite");

// Benford: δύο επίπεδα περιόδου (έτος + "all"), όχι το ίδιο σχήμα με τους
// υπόλοιπους δείκτες -- προτιμάται το πιο πρόσφατο έτος με N>=300, αλλιώς
// fallback στο "all" (SPRINT_E_PLAN §E6, ώστε η κάρτα να έχει νόημα και σε
// μεσαίους φορείς που δεν πιάνουν N=300 σε κανένα μεμονωμένο έτος).
const benfordSeries = page.indicators?.benford ?? {};
const benfordYearEntry = [...years].reverse()
  .map((y) => ({ year: y, entry: benfordSeries[String(y)] }))
  .find((r) => r.entry && !r.entry.insufficient_data);
const benfordAllEntry = benfordSeries["all"];
const benford = benfordYearEntry?.entry
  ? { latest: benfordYearEntry.entry, periodLabel: String(benfordYearEntry.year) }
  : benfordAllEntry && !benfordAllEntry.insufficient_data
    ? { latest: benfordAllEntry, periodLabel: "όλη η περίοδος" }
    : { latest: null, periodLabel: null };
const nigriniLabels: Record<string, string> = {
  close: "εντός τυπικών ορίων Nigrini (close)",
  acceptable: "εντός τυπικών ορίων Nigrini (acceptable)",
  marginal: "οριακά εκτός τυπικών ορίων Nigrini (marginal)",
  nonconformity: "εκτός τυπικών ορίων Nigrini (nonconformity)",
};
const benfordBandLabel = benford.latest?.band ? (nigriniLabels[benford.latest.band] ?? benford.latest.band) : null;
const benfordPoints = years.map((y) => {
  const entry = benfordSeries[String(y)];
  return { year: y, value: entry && !entry.insufficient_data ? entry.value : null };
});

const correctionFormUrl = `/diorthoseis/?vat=${encodeURIComponent(vat ?? "")}&name=${encodeURIComponent(page.name ?? "")}#form`;

// S3 (audit): validate ADAM format before building the URL -- ο ΑΔΑΜ μπαίνει
// σε href attribute χωρίς αυτόν τον έλεγχο θα μπορούσε ένα μη τυπικό string
// (π.χ. scheme "javascript:") να περάσει ως τιμή, παρότι το Astro κάνει escape
// το attribute περιεχόμενο.
const ADAM_RE = /^\d{2}(REQ|PROC|AWRD|SYMV|PAY)\d+$/;
const isValidAdam = (adam: unknown): adam is string => typeof adam === "string" && ADAM_RE.test(adam);
const adamUrl = (adam: string) => `https://cerpp.eprocurement.gov.gr/khmdhs-opendata/auction/attachment/${encodeURIComponent(adam)}`;
---
<Base title={page.name ?? vat} description={`Δείκτες διαφάνειας διαδικασιών για ${page.name ?? vat} (ΑΦΜ ${vat}).`}>
  <div class="foreas-header">
    <div>
      <h1>{page.name ?? "Άγνωστος φορέας"}</h1>
      <p class="subtitle">
        {page.org_type || page.classification || "Φορέας"} · {page.nuts_city || "Χωρίς περιοχή"} · ΑΦΜ {vat}
        {years.length > 0 && <> · Κάλυψη δεδομένων {years[0]}–{years[years.length - 1]}</>}
      </p>
    </div>
    <div class="foreas-actions">
      <a class="button-outline" href="/dedomena/">Κατέβασε τα δεδομένα (CSV)</a>
      <a class="button-outline" href={correctionFormUrl}>Υπέβαλε διόρθωση/απάντηση</a>
    </div>
  </div>

  {latestOverview ? (
    <section>
      <div class="period-panel" data-period-panel>
        <div class="period-controls">
          <label>
            Περίοδος
            <select id="period-mode">
              <option value="latest">Τελευταίο έτος</option>
              <option value="all">Ολόκληρη περίοδος</option>
              <option value="custom">Custom εύρος</option>
            </select>
          </label>
          <label>
            Από
            <select id="period-from"></select>
          </label>
          <label>
            Έως
            <select id="period-to"></select>
          </label>
        </div>
        <div id="period-summary" class="stat-tiles"></div>
      </div>

      <div class="chart-panel">
        <div set:html={stackedSvg} />
        <p class="chart-caption">Αξία αναθέσεων ανά έτος — σκούρο μπλε: απευθείας (εκτίμηση από % πλήθους) · ανοιχτό μπλε: ανταγωνιστικές. Ονομαστικές τιμές.</p>
      </div>

      {page.top_cpv?.length > 0 && (
        <div class="table-block">
          <h2>Τι αγοράζει</h2>
          <table class="plain-table">
            <thead><tr><th>Κατηγορία CPV</th><th>Αξία</th></tr></thead>
            <tbody>
              {page.top_cpv.map((c: any) => (
                <tr><td>{c.label} <span class="muted">({c.code})</span></td><td>{eur(c.value)}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {page.top_contractors?.length > 0 && (
        <div class="table-block">
          <h2>Από ποιον</h2>
          <table class="plain-table">
            <thead><tr><th>Ανάδοχος</th><th>Αξία</th><th>Μερίδιο</th></tr></thead>
            <tbody>
              {page.top_contractors.map((c: any) => (
                <tr><td>{c.name}</td><td>{eur(c.value)}</td><td>{c.share !== null ? `${c.share}%` : "—"}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  ) : (
    <div class="empty-state">Δεν βρέθηκαν αναθέσεις για αυτόν τον φορέα στο τρέχον dataset.</div>
  )}

  <section>
    <h2>Δείκτες διαφάνειας διαδικασιών</h2>
    <p class="subtitle">Στατιστικοί δείκτες ρίσκου διαδικασιών — όχι διαπιστώσεις παρανομίας.</p>
    <div class="entry-cards">
      <IndicatorCard
        title="% Απευθείας ανάθεση"
        info="Μερίδιο αναθέσεων με τη διαδικασία «Απευθείας ανάθεση» σε πλήθος. Μικροί φορείς με λίγες προμήθειες έχουν φυσιολογικά υψηλό ποσοστό — δείτε πάντα το N."
        defLink="/methodologia/#41-ποσοστό-απευθείας-αναθέσεων"
        latestValue={da.latest?.value ?? null}
        latestYear={latestYear}
        latestN={da.latest?.n ?? null}
        valueFormat="pct"
        points={da.points}
        hist={da.hist}
        percentile={da.percentile}
        caveat="Πιθανές νόμιμες εξηγήσεις: εξειδικευμένη αγορά, μικρός προϋπολογισμός, επείγουσες ανάγκες."
      />
      <IndicatorCard
        title="Συγκέντρωση αναδόχων (HHI)"
        info="Πόσο συγκεντρωμένη είναι η δαπάνη σε λίγους αναδόχους (0–1). Απαιτείται ελάχιστο N≥10 συμβάσεων."
        defLink="/methodologia/#42-συγκέντρωση-αναδόχων-hhi--top-1-μερίδιο"
        latestValue={hhi.latest?.value ?? null}
        latestYear={latestYear}
        latestN={hhi.latest?.n ?? null}
        valueFormat="hhi"
        points={hhi.points}
        hist={hhi.hist}
        percentile={hhi.percentile}
        caveat="Πιθανές νόμιμες εξηγήσεις: εξειδικευμένη αγορά με λίγους πιστοποιημένους προμηθευτές."
      />
      <IndicatorCard
        title="Διάμεση έκπτωση"
        info="Διαφορά εκτιμώμενης προς τελική αξία ανάθεσης. Συστηματικά ~0% έκπτωση σε ανταγωνιστικές διαδικασίες είναι καθιερωμένο red flag."
        defLink="/methodologia/#46-ποσοστό-έκπτωσης-προκήρυξης--σύμβασης"
        latestValue={discount.latest?.value ?? null}
        latestYear={latestYear}
        latestN={discount.latest?.n ?? null}
        valueFormat="pct"
        points={discount.points}
        hist={discount.hist}
        percentile={discount.percentile}
        insufficientData={discount.latest?.insufficient_coverage ?? true}
        coverageNote={discount.latest ? `Κάλυψη σύνδεσης προκήρυξης↔ανάθεσης: ${discount.latest.coverage_pct ?? "—"}%` : null}
        caveat="Proxy μέσω τιμής κατακύρωσης λόγω περιορισμένης σύνδεσης notice↔contract στα δεδομένα ΚΗΜΔΗΣ."
      />
      <IndicatorCard
        title="Single-bid rate"
        info="Μερίδιο ανταγωνιστικών διαδικασιών με μία μόνο προσφορά, από τον πρώτο πλήρη μήνα κάλυψης bidsSubmitted."
        defLink="/deiktes/single-bid/"
        latestValue={singleBid.latest?.value ?? null}
        latestYear={latestYear}
        latestN={singleBid.latest?.n ?? null}
        valueFormat="pct"
        points={singleBid.points}
        hist={singleBid.hist}
        percentile={singleBid.percentile}
        insufficientData={singleBid.latest?.insufficient_data ?? true}
        coverageNote={singleBid.latest ? `Κάλυψη bidsSubmitted: ${singleBid.latest.coverage_pct ?? "—"}%` : null}
        caveat="Δεν είναι ιστορική σειρά πριν από το cutover 2025-04· garbage τιμές bidsSubmitted εξαιρούνται ως data errors."
      />
      <IndicatorCard
        title="Διάμεση προθεσμία υποβολής"
        info="Ημέρες από τη δημοσίευση της προκήρυξης έως την καταληκτική ημερομηνία υποβολής προσφορών, σε ανταγωνιστικές διαδικασίες (οι απευθείας αναθέσεις εξαιρούνται)."
        defLink="/methodologia/#47-σύντομες-προθεσμίες-υποβολής"
        latestValue={deadline.latest?.value ?? null}
        latestYear={latestYear}
        latestN={deadline.latest?.n ?? null}
        valueFormat="days"
        points={deadline.points}
        hist={deadline.hist}
        percentile={deadline.percentile}
        insufficientData={deadline.latest?.insufficient_data ?? true}
        coverageNote={deadline.latest ? `Κάλυψη έγκυρων ημερομηνιών: ${deadline.latest.coverage_pct ?? "—"}%` : null}
        caveat="Το ποσοστό διαδικασιών με «σύντομη» προθεσμία δεν δημοσιεύεται ακόμα -- εκκρεμεί νομική επιβεβαίωση ελάχιστων ορίων ανά τύπο διαδικασίας."
      />
      <IndicatorCard
        title="Σύνθετος δείκτης"
        info="Μη σταθμισμένος μέσος των διαθέσιμων δημοσιευμένων flags. Δεν περιλαμβάνει bid-splitting ή pct_short_deadline."
        defLink="/deiktes/composite/"
        latestValue={composite.latest?.value ?? null}
        latestYear={latestYear}
        latestN={composite.latest?.n ?? null}
        valueFormat="raw"
        points={composite.points}
        hist={composite.hist}
        percentile={composite.percentile}
        caveat="Διαβάζεται μόνο μαζί με τα επιμέρους flags και τα N τους· δεν είναι αυτοτελής κατάταξη νομιμότητας."
      />
      <IndicatorCard
        title="Έλεγχος Benford (κατανομή ψηφίων)"
        info="Μέση απόλυτη απόκλιση (MAD) της κατανομής του 1ου ψηφίου των ποσών πληρωμών από την αναμενόμενη κατανομή Benford, με τα κατώφλια Nigrini. Ελάχιστο N=300 έγκυρα ποσά."
        defLink="/deiktes/benford/"
        latestValue={benford.latest?.value ?? null}
        latestYear={null}
        periodLabel={benford.periodLabel}
        latestN={benford.latest?.n ?? null}
        valueFormat="raw"
        points={benfordPoints}
        hist={null}
        percentile={null}
        insufficientData={!benford.latest}
        coverageNote={benford.latest ? `Ζώνη Nigrini: ${benfordBandLabel} · Κάλυψη εγκυρότητας ποσών: ${benford.latest.coverage_pct ?? "—"}%` : null}
        caveat="Δευτερεύον στατιστικό σήμα, ποτέ μόνο του -- θεσμικά κατώφλια (π.χ. όρια απευθείας ανάθεσης) παράγουν φυσιολογικές αποκλίσεις από την κατανομή Benford."
      />
    </div>
  </section>

  {page.network && (
    <section>
      <h2>Δίκτυο</h2>
      <p class="subtitle">
        Δομική ανάλυση δικτύου φορέα-αναδόχων πάνω στο ίδιο ΚΗΜΔΗΣ dataset —{" "}
        <a href="/methodologia/#410-δείκτες-δικτύου">δείτε τους περιορισμούς πριν ερμηνεύσετε</a>.
        Δεν αποδεικνύει ούτε υπονοεί συμφωνία μεταξύ φορέα και αναδόχου.
      </p>
      <p class="muted">Δεδομένα δικτύου: snapshot {page.network.snapshot_date ?? "άγνωστο"} (offline, χειροκίνητη ανανέωση περιοδικά).</p>

      {(() => {
        const years = Object.keys(page.network.new_winner_rate ?? {}).sort();
        const latestNwrYear = years.length ? years[years.length - 1] : null;
        const latestNwr = latestNwrYear ? page.network.new_winner_rate[latestNwrYear] : null;
        return latestNwr ? (
          <div class="stat-tiles">
            <div class="stat-tile">
              <div class="value">{latestNwr.value}%</div>
              <div class="label">Ρυθμός νέων αναδόχων</div>
              <div class="period">N={latestNwr.n} · {latestNwrYear}</div>
            </div>
          </div>
        ) : (
          <p class="badge-missing">Ανεπαρκή δεδομένα για ρυθμό νέων αναδόχων</p>
        );
      })()}

      {page.network.top_neighbors?.length > 0 ? (
        <div class="table-block">
          <h3>Top γείτονες (ego-network, top-30)</h3>
          <div class="table-wrap">
            <table class="plain-table">
              <thead><tr><th>Ανάδοχος</th><th>Αξία</th><th>Ν αναθέσεων</th><th>Μερίδιο</th></tr></thead>
              <tbody>
                {page.network.top_neighbors.map((n: any) => (
                  <tr>
                    <td>{n.vat && profiledVats.has(n.vat) ? <a href={`/anadoxos/${n.vat}/`}>{n.name ?? n.vat}</a> : (n.name ?? "—")}</td>
                    <td>{eur(n.value)}</td>
                    <td>{nf.format(n.n_awards)}</td>
                    <td>{n.share !== null && n.share !== undefined ? `${n.share}%` : "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ) : (
        <p class="badge-missing">Ανεπαρκή δεδομένα για γείτονες δικτύου</p>
      )}
    </section>
  )}

  {page.replies?.length > 0 && (
    <section>
      <h2>Δικαίωμα απάντησης</h2>
      <p class="muted">
        Απαντήσεις/εξηγήσεις που κατέθεσε ο φορέας, δημοσιευμένες αυτούσιες
        (βλ. <a href="/apopoiisi/">δικαίωμα απάντησης</a>).
      </p>
      {page.replies.map((r: any) => (
        <div class="reply-card">
          <div class="reply-meta">
            <span>{r.date}</span>
            {r.sender_role && <span> · {r.sender_role}</span>}
            {r.indicator && <span> · δείκτης: {r.indicator}</span>}
          </div>
          <p class="reply-text">{r.text}</p>
        </div>
      ))}
    </section>
  )}

  {page.recent?.length > 0 && (
    <section>
      <h2>Πρόσφατες αναθέσεις</h2>
      <div class="table-wrap">
        <table class="plain-table">
          <thead>
            <tr><th>Ημερομηνία</th><th>Τίτλος</th><th>Ανάδοχος</th><th>Ποσό (με ΦΠΑ)</th><th>Διαδικασία</th><th>ΑΔΑΜ</th></tr>
          </thead>
          <tbody>
            {page.recent.map((r: any) => (
              <tr>
                <td>{r.date}</td>
                <td>{r.title}</td>
                <td>{r.contractor_name ?? "—"}</td>
                <td>{eur(r.amount_with_vat)}</td>
                <td>{r.procedure}</td>
                <td>{isValidAdam(r.adam) ? <a href={adamUrl(r.adam)} target="_blank" rel="noopener">{r.adam}</a> : (r.adam ?? "—")}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</Base>

<script define:vars={{ overview: page.overview, years }}>
  const nf = new Intl.NumberFormat("el-GR", { maximumFractionDigits: 0 });
  const eur = (value) => value === null || value === undefined ? "—" : `${nf.format(value)} €`;
  const mode = document.getElementById("period-mode");
  const from = document.getElementById("period-from");
  const to = document.getElementById("period-to");
  const summary = document.getElementById("period-summary");

  function fillYears() {
    for (const select of [from, to]) {
      select.replaceChildren();
      for (const y of years) {
        const opt = document.createElement("option");
        opt.value = String(y);
        opt.textContent = String(y);
        select.append(opt);
      }
    }
    from.value = String(years[0]);
    to.value = String(years[years.length - 1]);
  }

  function selectedYears() {
    if (mode.value === "latest") return [years[years.length - 1]];
    if (mode.value === "all") return years;
    const a = Number(from.value);
    const b = Number(to.value);
    const lo = Math.min(a, b);
    const hi = Math.max(a, b);
    return years.filter((y) => y >= lo && y <= hi);
  }

  function renderPeriod() {
    const ys = selectedYears();
    const rows = ys.map((y) => overview[String(y)] || {});
    const totalValue = rows.reduce((sum, r) => sum + (Number(r.value_total) || 0), 0);
    const totalN = rows.reduce((sum, r) => sum + (Number(r.n_total) || 0), 0);
    const directN = rows.reduce((sum, r) => sum + (Number(r.n_direct) || 0), 0);
    const contractors = rows.reduce((sum, r) => sum + (Number(r.n_unique_contractors) || 0), 0);
    const daPct = totalN ? (100 * directN) / totalN : null;
    const periodLabel = ys.length === 1 ? String(ys[0]) : `${ys[0]}–${ys[ys.length - 1]}`;
    summary.innerHTML = `
      <div class="stat-tile"><div class="value">${eur(totalValue)}</div><div class="label">Συνολική αξία περιόδου</div><div class="period">${periodLabel}</div></div>
      <div class="stat-tile"><div class="value">${nf.format(totalN)}</div><div class="label">Πλήθος αναθέσεων</div><div class="period">${periodLabel}</div></div>
      <div class="stat-tile"><div class="value">${daPct === null ? "—" : `${daPct.toFixed(1)}%`}</div><div class="label">% απευθείας σε πλήθος</div><div class="period">N=${nf.format(totalN)} · ${periodLabel}</div></div>
      <div class="stat-tile"><div class="value">${nf.format(contractors)}</div><div class="label">Άθροισμα μοναδικών αναδόχων ανά έτος</div><div class="period">${periodLabel}</div></div>`;
  }

  if (years.length) {
    fillYears();
    renderPeriod();
    for (const el of [mode, from, to]) el.addEventListener("change", renderPeriod);
  }
</script>

